# このファイルを .env.local にコピーして値を埋めてください。
# コピー例（PowerShell）: Copy-Item env.local.example .env.local

# Neon PostgreSQL の接続文字列
# Neon ダッシュボード → Connection Details → Connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

